{
  "name": "cc-boost",
  "version": "0.1.0",
  "description": "Open-source Claude Code output filter - token reduction via ANSI stripping, stack trace folding, and interactive scaffold interception",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "install:plugin": "node build.mjs && node install.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
