{
  "description": "cc-boost output filter and scaffold interceptor hooks",
  "hooks": {
    "Setup": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/plugins/marketplaces/cc-boost/plugin/scripts/smart-install.js\"",
            "timeout": 300
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/plugins/marketplaces/cc-boost/plugin/scripts/pre-tool-use.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
